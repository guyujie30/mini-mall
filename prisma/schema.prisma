generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// 用户模型
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String
  role          String    @default("CUSTOMER")
  memberId      String?
  member        Member?   @relation(fields: [memberId], references: [id])
  orders        Order[]
  addresses     Address[]
  cartItems     CartItem[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// 会员等级模型
model Member {
  id          String      @id @default(cuid())
  level       Int         @unique // 1, 2, 3
  name        String      // 普通会员、银卡会员、金卡会员
  minAmount   Float       @default(0) // 最低消费额度
  discount    Float       @default(1.0) // 折扣率 (0.95 = 95折)
  description String?
  users       User[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// 商品分类
model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  image       String?
  products    Product[]
  createdAt   DateTime  @default(now())
}

// 商品
model Product {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String
  price       Float
  images      String      @default("[]") // JSON 数组
  stock       Int         @default(0)
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
  cartItems   CartItem[]
  isActive    Boolean     @default(true)
  isFeatured  Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// 购物车
model CartItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
}

// 订单
model Order {
  id             String   @id @default(cuid())
  orderNo        String   @unique
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  addressId      String
  address        Address  @relation(fields: [addressId], references: [id])
  items          OrderItem[]
  totalAmount    Float
  discountAmount Float    @default(0)
  finalAmount    Float
  memberLevel    Int?     // 下单时的会员等级
  status         String   @default("PENDING")
  paymentId      String?
  paidAt         DateTime?
  shippedAt      DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// 订单项
model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
  subtotal  Float
}

// 用户地址
model Address {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  phone     String
  province  String
  city      String
  district  String
  detail    String
  isDefault Boolean  @default(false)
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
